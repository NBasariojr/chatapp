# Backend

# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>

# Authentication
JWT_SECRET=<64-character-hex>
JWT_EXPIRES_IN=7d

# Supabase (File Storage)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<service-role-key>
SUPABASE_BUCKET=<bucket-name>

# Redis
REDIS_URL=redis://localhost:6379

# Email — Resend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@mail.yourdomain.com

# OAuth
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>

# Client URL
CLIENT_URL=http://localhost:5173

# Sentry (optional)
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
SENTRY_RELEASE=


# Web (apps/web)

# Backend API + Socket.IO URL
VITE_API_URL=https://your-backend.onrender.com

# Supabase
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_KEY=<anon-key>

# Google OAuth
VITE_GOOGLE_CLIENT_ID=<vite-google-client-id>

# ngrok
VITE_NGROK_URL=https://your-ngrok-url.ngrok-free.app

# Sentry
VITE_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
VITE_SENTRY_RELEASE=chatapp-web@0.0.0

# Build-time only (not VITE_ prefixed — never sent to browser)
SENTRY_AUTH_TOKEN=sntrys_xxxx
SENTRY_ORG=your-org-slug
SENTRY_PROJECT_WEB=chatapp-web