# Backend
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<64-char-hex-string>
JWT_EXPIRES_IN=7d

# Supabase — from your project settings → API
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<service-role-key>
SUPABASE_BUCKET=<bucket-name>

# Redis
# Local dev:      redis://localhost:6379
# Upstash (prod): rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# Frontend base URL — used in password reset email links
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# ngrok — auto-patched by pnpm tunnel script, do not set manually
NGROK_URL=https://your-ngrok-url.ngrok-free.app

# Email — Gmail SMTP via Nodemailer
# Setup: Google Account → Security → App Passwords → Generate
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=<16-char-app-password-no-spaces>
EMAIL_FROM=ChatApp <yourname@gmail.com>

# Google OAuth — get from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# Sentry error monitoring — optional, leave blank to disable
SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0

# Web (apps/web)
# Only needed in production (Vercel). In dev, Vite proxy handles /api/* routing.
# VITE_API_URL=https://your-backend.onrender.com

# Google OAuth - Frontend
VITE_GOOGLE_CLIENT_ID=<your-google-client-id>