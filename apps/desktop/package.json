{
    "name": "@chatapp/desktop",
    "version": "1.0.0",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "electron:dev": "concurrently \"vite\" \"wait-on tcp:3001 && electron .\"",
        "electron:build": "tsc && vite build && electron-builder",
        "preview": "vite preview"
    },
    "dependencies": {
        "@chatapp/shared": "workspace:*",
        "@reduxjs/toolkit": "^2.1.0",
        "axios": "^1.6.7",
        "framer-motion": "^11.0.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-redux": "^9.1.0",
        "react-router-dom": "^6.22.0",
        "socket.io-client": "^4.6.2"
    },
    "devDependencies": {
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "concurrently": "^8.2.2",
        "electron": "^39.8.5",
        "electron-builder": "^24.9.1",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3",
        "vite": "^5.1.0",
        "vite-plugin-electron": "^0.28.4",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.chatapp.desktop",
        "productName": "ChatApp",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "dist-electron/**/*"
        ],
        "win": {
            "target": "nsis"
        },
        "mac": {
            "target": "dmg"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}