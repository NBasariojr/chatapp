# Example environment variables

# Backend API + Socket.IO URL
# Dev:  Leave unset — Vite proxy handles /api/* → localhost:4000
#       Socket.IO connects to http://localhost:4000 directly (fallback)
# Prod: Set to your Render backend URL in the Vercel dashboard
VITE_API_URL=https://your-backend.onrender.com

# Supabase — anon/public key (client-side, governed by RLS policies)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_KEY=<anon-key>

# Google OAuth — get from Google Cloud Console (Credentials → OAuth 2.0 Client IDs)
VITE_GOOGLE_CLIENT_ID=

# ngrok — auto-patched by pnpm tunnel, do not set manually
VITE_NGROK_URL=