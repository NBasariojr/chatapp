# Test Environment Configuration

# Environment
NODE_ENV=test

# Server
PORT=3001

# Database - MongoDB Memory Server (in-memory)
MONGODB_URI=mongodb://localhost:27017/chatapp-test

# JWT - Test-only secrets
JWT_SECRET=test_jwt_secret_key_for_testing_only
JWT_EXPIRES_IN=7d

# Supabase - Test values (can be fake for tests)
SUPABASE_URL=https://test.supabase.co
SUPABASE_KEY=test_supabase_key_for_testing
SUPABASE_BUCKET=test-bucket

# Email - Test configuration (can be fake for tests)
RESEND_API_KEY=test_resend_api_key_for_testing
EMAIL_FROM=test@example.com

# Redis - Optional for tests (will be mocked)
REDIS_URL=redis://localhost:6379

# Client URL
CLIENT_URL=http://localhost:3000

# OAuth - Test credentials (can be fake for tests)
GOOGLE_CLIENT_ID=test_google_client_id_for_testing
GOOGLE_CLIENT_SECRET=test_google_client_secret_for_testing

# Sentry - Disabled for tests
SENTRY_DSN=
SENTRY_RELEASE=

# Feature Flags
ENABLE_NEW_CHAT=false
MESSAGE_RETENTION_DAYS=30
RATE_LIMIT_STRICT=false

# Note: Test users are now generated dynamically via TestUserFactory
# No need for hardcoded test credentials in environment variables
