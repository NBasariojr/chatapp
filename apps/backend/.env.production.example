# Production Environment Configuration

# Environment
NODE_ENV=production

# Server
PORT=3001

# Database - MongoDB Production
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/chatapp-prod

# JWT - Production secrets (use strong, unique secrets)
JWT_SECRET=your_production_jwt_secret_key_change_this_immediately
JWT_EXPIRES_IN=7d

# Supabase - Production configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here
SUPABASE_BUCKET=chatapp-prod

# Email - Resend for production
RESEND_API_KEY=your_production_resend_api_key
EMAIL_FROM=noreply@yourdomain.com

# Redis - Production cache
REDIS_URL=redis://username:password@your-redis-host:6379

# Client URL
CLIENT_URL=https://yourdomain.com

# OAuth - Google OAuth Production
GOOGLE_CLIENT_ID=your_production_google_client_id
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Sentry - Error tracking (recommended for production)
SENTRY_DSN=your_production_sentry_dsn
SENTRY_RELEASE=chatapp@1.0.0

# Feature Flags
ENABLE_NEW_CHAT=true
MESSAGE_RETENTION_DAYS=90
RATE_LIMIT_STRICT=true
