# Development Environment Configuration

# Environment
NODE_ENV=development

# Server
PORT=3001

# Database - MongoDB
MONGODB_URI=mongodb://localhost:27017/chatapp-dev

# JWT - Development secrets (change these for production)
JWT_SECRET=your_development_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Supabase - Development configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_BUCKET=chatapp-dev

# Email - Resend for development
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=your-email@example.com

# Redis - Development cache
REDIS_URL=redis://localhost:6379

# Client URL
CLIENT_URL=http://localhost:3000

# OAuth - Google OAuth (get from Google Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Sentry - Error tracking (optional for development)
SENTRY_DSN=your_sentry_dsn_here
SENTRY_RELEASE=chatapp@1.0.0

# Feature Flags
ENABLE_NEW_CHAT=true
MESSAGE_RETENTION_DAYS=30
RATE_LIMIT_STRICT=false
