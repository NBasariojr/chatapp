# Port your backend runs on
PORT=4000
NODE_ENV=development

# DATABASE
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# AUTHENTICATION (JWT)
JWT_SECRET=<64-character-random-hex-string>
JWT_EXPIRES_IN=7d

# SUPABASE (File Storage / CDN)
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<supabase-service-role-key>
SUPABASE_BUCKET=<bucket-name>

# REDIS (Caching / Sessions / Rate Limiting)
REDIS_URL=redis://localhost:6379

# Sentry
# Get DSN from: sentry.io → Project → Settings → Client Keys
SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
# Set in Render deploy hook: SENTRY_RELEASE=$(git rev-parse --short HEAD)
SENTRY_RELEASE=

# CLIENT / FRONTEND URL
CLIENT_URL=http://localhost:5173

# TUNNELING (NGROK)
NGROK_URL=<your-ngrok-url>

# EMAIL SERVICE (Nodemailer / SMTP)
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=<gmail-app-password>
EMAIL_FROM="ChatApp Support <yourname@gmail.com>"

# OAUTH (Google Login)
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
